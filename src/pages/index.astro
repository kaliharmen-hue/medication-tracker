---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout>
  <section class="page-head compact">
    <div>
      <p class="eyebrow">Today</p>
      <h1>Daily check-in</h1>
      <p class="lede">Fill only what feels useful. Changes autosave as you go, with a separate space for Kali to add notes.</p>
    </div>
    <div class="save-state" id="saveState">Autosaves as I go</div>
  </section>

  <section class="control-strip" aria-label="Entry controls">
    <label>
      <span>Date</span>
      <input id="dateInput" type="date" />
    </label>
    <a class="button ghost" id="exportLink" href="./export/">Export day</a>
  </section>

  <form id="dailyForm" class="daily-form"></form>

  <section class="copy-panel" aria-labelledby="copyTitle">
    <div>
      <h2 id="copyTitle">ChatGPT day copy</h2>
      <p>Copies everything saved for the selected date. If a day is backfilled later, choose that date first.</p>
    </div>
    <button class="button" id="copyChatGpt" type="button">Copy this day for ChatGPT</button>
    <p class="copy-status" id="copyStatus" aria-live="polite"></p>
    <textarea id="copyFallback" class="copy-fallback" readonly hidden></textarea>
  </section>

  <section class="quiet-panel" id="syncPanel">
    <h2>Shared saving</h2>
    <p id="syncText">Checking save setup...</p>
  </section>
</BaseLayout>
<script>
  import "../scripts/today.ts";
</script>
